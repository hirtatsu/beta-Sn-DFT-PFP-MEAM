variable ly0 equal 5.85888341444202
variable tmp equal lz
variable lz0 equal ${tmp}
variable lz0 equal 3.20590424121512

# These formulas define the derivatives w.r.t. strain components
# Constants uses $, variables use v_
variable d1 equal -(v_pxx1-${pxx0})/(v_delta/v_len0)*${cfac}
variable d1 equal -(v_pxx1--1.09710380381989e-10)/(v_delta/v_len0)*${cfac}
variable d1 equal -(v_pxx1--1.09710380381989e-10)/(v_delta/v_len0)*0.0001
variable d2 equal -(v_pyy1-${pyy0})/(v_delta/v_len0)*${cfac}
variable d2 equal -(v_pyy1--1.01473293360239e-10)/(v_delta/v_len0)*${cfac}
variable d2 equal -(v_pyy1--1.01473293360239e-10)/(v_delta/v_len0)*0.0001
variable d3 equal -(v_pzz1-${pzz0})/(v_delta/v_len0)*${cfac}
variable d3 equal -(v_pzz1--6.67557863443338e-10)/(v_delta/v_len0)*${cfac}
variable d3 equal -(v_pzz1--6.67557863443338e-10)/(v_delta/v_len0)*0.0001
variable d4 equal -(v_pyz1-${pyz0})/(v_delta/v_len0)*${cfac}
variable d4 equal -(v_pyz1--2.14834598618855e-12)/(v_delta/v_len0)*${cfac}
variable d4 equal -(v_pyz1--2.14834598618855e-12)/(v_delta/v_len0)*0.0001
variable d5 equal -(v_pxz1-${pxz0})/(v_delta/v_len0)*${cfac}
variable d5 equal -(v_pxz1-4.16291899108445e-12)/(v_delta/v_len0)*${cfac}
variable d5 equal -(v_pxz1-4.16291899108445e-12)/(v_delta/v_len0)*0.0001
variable d6 equal -(v_pxy1-${pxy0})/(v_delta/v_len0)*${cfac}
variable d6 equal -(v_pxy1--1.10269507492876e-14)/(v_delta/v_len0)*${cfac}
variable d6 equal -(v_pxy1--1.10269507492876e-14)/(v_delta/v_len0)*0.0001

displace_atoms all random ${atomjiggle} ${atomjiggle} ${atomjiggle} 87287 units box
displace_atoms all random 1e-05 ${atomjiggle} ${atomjiggle} 87287 units box
displace_atoms all random 1e-05 1e-05 ${atomjiggle} 87287 units box
displace_atoms all random 1e-05 1e-05 1e-05 87287 units box
