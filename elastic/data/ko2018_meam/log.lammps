if "${dir} == 2" then    "change_box all y delta 0 ${delta} yz delta ${deltayz} remap units box"
change_box all y delta 0 ${delta} yz delta ${deltayz} remap units box
change_box all y delta 0 0.000585888341444202 yz delta ${deltayz} remap units box
change_box all y delta 0 0.000585888341444202 yz delta 0 remap units box
